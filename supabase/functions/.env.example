# Variables d'environnement pour les Edge Functions Supabase en local.
#
# Copier ce fichier en `supabase/functions/.env` puis remplir les valeurs.
# Le fichier `.env` est ignoré par git (cf. .gitignore racine).
#
# Comment l'utiliser :
#   npx supabase functions serve --env-file supabase/functions/.env
#
# En production, ces variables doivent être poussées comme secrets Supabase :
#   npx supabase secrets set --project-ref <prod-ref> --env-file supabase/functions/.env
#
# La référence complète des secrets attendus est dans :
#   docs/SUPABASE_PRODUCTION.md
#   docs/LOCAL_DATABASES.md

# --- Brevo (emails + SMS transactionnels) ---
# Utilisé par : send-contact-verification-code, create-document-request
BREVO_API_KEY=
BREVO_EMAIL_SENDER=noreply@powerprestation.ca
BREVO_EMAIL_SENDER_NAME=Power Prestation
BREVO_SMS_SENDER=PowerPresta
# Mettre `true` pour que Brevo accepte la requête email sans envoyer réellement.
BREVO_SANDBOX_MODE=false
